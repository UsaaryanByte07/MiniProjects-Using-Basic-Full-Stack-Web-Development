<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-pink-50 to-purple-50 min-h-screen">
    <%- include('../partials/navbar') %>
    <div class="py-12 px-4">
    <div class="max-w-md mx-auto bg-white rounded-xl shadow-lg p-8">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800 mb-2"><%= isEditing ? "Edit": "Add"%> Your Home</h1>
            <p class="text-gray-600"><%= isEditing ? "Edit": "List"%> your property on Apka Apna Airbnb</p>
        </div>  
        <% if (errorMsgs && errorMsgs.length > 0) { %>
            <div class="mb-4">
                <% errorMsgs.forEach(msg => { %>
                    <p class="text-red-500 text-sm"><%= msg %></p>
                <% }) %>
            </div>
        <% } %>
        <form action="/host/<%= isEditing ? "edit-home":"add-home"%>" method="post" enctype="multipart/form-data" class="space-y-6">
            <input type="hidden" name="_id" value="<%= isEditing ? home._id : ''%>">
            <div>
                <label for="homeName" class="block text-sm font-medium text-gray-700 mb-2">
                    Property Name
                </label>
                <input 
                    type="text" 
                    name="homeName" 
                    id="homeName"
                    value='<%= isEditing ? home.homeName: ""%>'
                    placeholder="Enter the House Name"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition duration-200 ease-in-out"
                    required
                >
            </div>
            <div>
                <label for="price" class="block text-sm font-medium text-gray-700 mb-2">
                    Enter the Price in ₹ and per Night
                </label>
                <input 
                    type="number" 
                    name="price" 
                    id="price"
                    value="<%= isEditing ? home.price: ""%>"
                    placeholder="Enter the Price"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition duration-200 ease-in-out"
                    required
                >
            </div>
            <div>
                <label for="location" class="block text-sm font-medium text-gray-700 mb-2">
                    Enter the Location
                </label>
                <input 
                    type="text" 
                    name="location" 
                    id="location"
                    value="<%= isEditing ? home.location: ""%>"
                    placeholder="Enter the Location"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition duration-200 ease-in-out"
                    required
                >
            </div>
            <div>
                <label for="rating" class="block text-sm font-medium text-gray-700 mb-2">
                    Give the Rating
                </label>
                <input 
                    type="number" 
                    name="rating" 
                    id="rating" 
                    value="<%= isEditing ? home.rating: ""%>"
                    placeholder="Enter the Rating Out of 5"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition duration-200 ease-in-out"
                    step="0.1"
                    min="0"
                    max="5"
                    required
                >
            </div>
            <div>
                <label for="photo" class="block text-sm font-medium text-gray-700 mb-2">
                    Upload the Home Photo
                </label>
                <input 
                    type="file" 
                    name="photo" 
                    id="photo" 
                    accept="image/*"
                    class="w-full text-sm text-gray-700 border-2 border-dashed border-pink-300 rounded-lg bg-pink-50/60 p-3 cursor-pointer focus:outline-none focus:ring-2 focus:ring-pink-500 transition duration-200 ease-in-out file:mr-4 file:cursor-pointer file:rounded-md file:border-0 file:bg-gradient-to-r file:from-pink-500 file:to-purple-600 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:from-pink-600 hover:file:to-purple-700"
                    <% if (!isEditing) { %>required<% } %>
                >
                <p class="mt-2 text-xs text-gray-500">Click the button to choose an image file from your device.</p>
            </div>
            <div>
                <label for="description" class="block text-sm font-medium text-gray-700 mb-2">
                    Property Description
                </label>
                <textarea 
                    name="description" 
                    id="description"
                    placeholder="Describe your property..."
                    rows="4"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition duration-200 ease-in-out resize-vertical"
                ><%= isEditing ? (home.description || ""): ""%></textarea>
            </div>
            <div class="flex space-x-4">
                <input 
                    type="submit" 
                    value="<%= isEditing ? "Update": "Add"%> Home"
                    class="flex-1 bg-gradient-to-r from-pink-500 to-purple-600 text-white py-3 px-6 rounded-lg font-semibold hover:from-pink-600 hover:to-purple-700 transition duration-300 ease-in-out transform hover:scale-105 cursor-pointer shadow-lg"
                >
                <a 
                    href="/host/host-homes" 
                    class="flex-1 bg-gray-500 text-white py-3 px-6 rounded-lg font-semibold hover:bg-gray-600 transition duration-300 ease-in-out text-center"
                >
                    Cancel
                </a>
            </div>
            
        </form>
    </div>
    </div>
</body>
</html>