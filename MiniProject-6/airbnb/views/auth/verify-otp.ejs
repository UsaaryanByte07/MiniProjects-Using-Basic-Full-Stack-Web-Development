<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-pink-50 via-purple-50 to-pink-100 min-h-screen">
    <%- include('../partials/navbar') %>
    
    <div class="flex items-center justify-center min-h-[80vh]">
        <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md mx-4">
            <div class="text-center mb-8">
                <h2 class="text-3xl font-bold text-gray-800 mb-2">Verify OTP</h2>
                <p class="text-gray-600">Enter the 6-digit code sent to your email</p>
                <% if (typeof email !== 'undefined') { %>
                    <p class="text-sm text-gray-500 mt-2">Code sent to: <span class="font-semibold"><%= email %></span></p>
                <% } %>
            </div>

            <!-- Error Messages -->
            <% if (typeof errMsgs !== 'undefined' && errMsgs.length > 0) { %>
                <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-red-800">
                                <% if (errMsgs.length === 1) { %>
                                    Please fix the following error:
                                <% } else { %>
                                    Please fix the following errors:
                                <% } %>
                            </h3>
                            <div class="mt-2 text-sm text-red-700">
                                <ul class="list-disc space-y-1 pl-5">
                                    <% errMsgs.forEach(function(error) { %>
                                        <li><%= error %></li>
                                    <% }); %>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>

            <form action="/verify-otp" method="POST" class="space-y-6">
                <!-- Hidden email input -->
                <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
                
                <!-- OTP Input -->
                <div class="space-y-2">
                    <label for="otp" class="block text-sm font-medium text-gray-700">
                        Verification Code
                    </label>
                    <input 
                        type="text" 
                        id="otp" 
                        name="otp" 
                        maxlength="6" 
                        pattern="[0-9]{6}"
                        placeholder="Enter 6-digit code"
                        required
                        class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-pink-500 focus:border-transparent outline-none transition-all duration-300 text-center text-2xl font-mono tracking-widest"
                        autocomplete="one-time-code"
                    >
                </div>

                <!-- Verify Button -->
                <button 
                    type="submit" 
                    class="w-full bg-gradient-to-r from-pink-500 to-purple-600 hover:from-pink-600 hover:to-purple-700 text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2"
                >
                    Verify OTP
                </button>
            </form>

            <!-- Resend OTP Link -->
            <!-- <div class="text-center mt-6">
                <p class="text-gray-600 text-sm">
                    Didn't receive the code? 
                    <a href="/resend-otp" class="text-pink-600 hover:text-pink-800 font-semibold transition-colors duration-300">
                        Resend OTP
                    </a>
                </p>
            </div> -->
        </div>
    </div>
    
</body>
</html>