<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-pink-50 via-purple-50 to-pink-100 min-h-screen">
    <%- include('../partials/navbar') %>
    
    <!-- Terms and Conditions Container -->
    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <!-- Header -->
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-gray-800 mb-4">Terms and Conditions</h1>
            <p class="text-gray-600 text-lg">Last updated: March 3, 2026</p>
        </div>

        <!-- Content Card -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl border border-pink-100 p-8 mb-8">
            
            <!-- Section 1: Agreement to Terms -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    1. Agreement to Terms
                </h2>
                <p class="text-gray-700 leading-relaxed">
                    By accessing and using Airbnb platform, you accept and agree to be bound by the terms and provision of this agreement. 
                    If you do not agree to abide by the above, please do not use this service.
                </p>
            </section>

            <!-- Section 2: User Accounts -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    2. User Accounts
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>When you create an account with us, you must provide information that is accurate, complete and current at all times.</p>
                    <p>You are responsible for safeguarding the password that you use to access the service and for all activities that occur under your account.</p>
                    <p>We offer two types of accounts:</p>
                    <ul class="list-disc list-inside ml-4 space-y-2">
                        <li><strong>Customer Account:</strong> For users who want to book and stay at properties</li>
                        <li><strong>Host Account:</strong> For users who want to list and manage rental properties</li>
                    </ul>
                </div>
            </section>

            <!-- Section 3: Booking and Payments -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    3. Booking and Payments
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>All bookings are subject to availability and confirmation by the host.</p>
                    <p>Payment processing is handled securely through our platform. We accept major credit cards and digital payment methods.</p>
                    <p>Cancellation policies vary by property and are clearly displayed at the time of booking.</p>
                </div>
            </section>

            <!-- Section 4: Host Responsibilities -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    4. Host Responsibilities
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>Hosts must provide accurate descriptions and photos of their properties.</p>
                    <p>Properties must meet basic safety and cleanliness standards.</p>
                    <p>Hosts are responsible for complying with local laws and regulations regarding short-term rentals.</p>
                </div>
            </section>

            <!-- Section 5: Guest Responsibilities -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    5. Guest Responsibilities
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>Guests must treat properties with respect and follow house rules.</p>
                    <p>Any damages caused during the stay may result in additional charges.</p>
                    <p>Guests must provide accurate information about the number of attendees and purpose of stay.</p>
                </div>
            </section>

            <!-- Section 6: Privacy and Data -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    6. Privacy and Data Protection
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>We collect and process personal data in accordance with our Privacy Policy.</p>
                    <p>Your data is protected using industry-standard security measures.</p>
                    <p>We do not sell personal information to third parties.</p>
                </div>
            </section>

            <!-- Section 7: Limitation of Liability -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    7. Limitation of Liability
                </h2>
                <p class="text-gray-700 leading-relaxed">
                    Airbnb acts as a platform connecting hosts and guests. We are not responsible for the conduct of hosts or guests, 
                    or for any property damage, personal injury, or other incidents that may occur during a stay.
                </p>
            </section>

            <!-- Section 8: Termination -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    8. Termination
                </h2>
                <p class="text-gray-700 leading-relaxed">
                    We may terminate or suspend your account immediately, without prior notice or liability, 
                    for any reason whatsoever, including without limitation if you breach the Terms.
                </p>
            </section>

            <!-- Section 9: Changes to Terms -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    9. Changes to Terms
                </h2>
                <p class="text-gray-700 leading-relaxed">
                    We reserve the right, at our sole discretion, to modify or replace these Terms at any time. 
                    If a revision is material, we will try to provide at least 30 days notice prior to any new terms taking effect.
                </p>
            </section>

            <!-- Contact Information -->
            <section class="bg-pink-50 rounded-lg p-6 border border-pink-200">
                <h2 class="text-xl font-semibold text-gray-800 mb-3">Contact Us</h2>
                <p class="text-gray-700">
                    If you have any questions about these Terms and Conditions, please contact us at:
                </p>
                <ul class="mt-3 text-gray-700">
                    <li>📧 Email: legal@airbnb.com</li>
                    <li>📞 Phone: +1 (555) 123-4567</li>
                    <li>📍 Address: 123 Main Street, San Francisco, CA 94105</li>
                </ul>
            </section>
        </div>

        <!-- Back to Signup Link -->
        <div class="text-center">
            <a href="/signup" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-700 hover:to-purple-700 text-white font-semibold rounded-lg transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Signup
            </a>
        </div>
    </div>
    
</body>
</html>