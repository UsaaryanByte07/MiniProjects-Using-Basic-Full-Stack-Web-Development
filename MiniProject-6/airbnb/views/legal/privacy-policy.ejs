<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-pink-50 via-purple-50 to-pink-100 min-h-screen">
    <%- include('../partials/navbar') %>
    
    <!-- Privacy Policy Container -->
    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <!-- Header -->
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-gray-800 mb-4">Privacy Policy</h1>
            <p class="text-gray-600 text-lg">Last updated: March 3, 2026</p>
        </div>

        <!-- Content Card -->
        <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl border border-pink-100 p-8 mb-8">
            
            <!-- Section 1: Information We Collect -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    1. Information We Collect
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>We collect information you provide directly to us, such as:</p>
                    <ul class="list-disc list-inside ml-4 space-y-2">
                        <li>Personal information (name, email, phone number)</li>
                        <li>Account credentials and profile information</li>
                        <li>Payment and billing information</li>
                        <li>Communication preferences</li>
                        <li>Property listings and booking details</li>
                    </ul>
                </div>
            </section>

            <!-- Section 2: How We Use Your Information -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    2. How We Use Your Information
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>We use the information we collect to:</p>
                    <ul class="list-disc list-inside ml-4 space-y-2">
                        <li>Provide, maintain, and improve our services</li>
                        <li>Process transactions and send related information</li>
                        <li>Send technical notices and security alerts</li>
                        <li>Communicate with you about our services</li>
                        <li>Personalize your experience on our platform</li>
                    </ul>
                </div>
            </section>

            <!-- Section 3: Information Sharing -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    3. Information Sharing
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>We do not sell, trade, or otherwise transfer your personal information to third parties, except:</p>
                    <ul class="list-disc list-inside ml-4 space-y-2">
                        <li>With your consent</li>
                        <li>To trusted service providers who assist our operations</li>
                        <li>When required by law or to protect our rights</li>
                        <li>In connection with a merger, sale, or acquisition</li>
                    </ul>
                </div>
            </section>

            <!-- Section 4: Data Security -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    4. Data Security
                </h2>
                <p class="text-gray-700 leading-relaxed">
                    We implement appropriate security measures to protect your personal information against unauthorized access, 
                    alteration, disclosure, or destruction. This includes encryption, secure servers, and regular security audits.
                </p>
            </section>

            <!-- Section 5: Your Rights -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    5. Your Rights
                </h2>
                <div class="text-gray-700 leading-relaxed space-y-3">
                    <p>You have the right to:</p>
                    <ul class="list-disc list-inside ml-4 space-y-2">
                        <li>Access and update your personal information</li>
                        <li>Delete your account and personal data</li>
                        <li>Opt out of marketing communications</li>
                        <li>Request a copy of your data</li>
                        <li>Report privacy concerns to us</li>
                    </ul>
                </div>
            </section>

            <!-- Section 6: Cookies -->
            <section class="mb-8">
                <h2 class="text-2xl font-semibold text-gray-800 mb-4 border-b border-pink-200 pb-2">
                    6. Cookies and Tracking
                </h2>
                <p class="text-gray-700 leading-relaxed">
                    We use cookies and similar tracking technologies to enhance your experience. 
                    You can control cookie preferences through your browser settings.
                </p>
            </section>

            <!-- Contact Information -->
            <section class="bg-pink-50 rounded-lg p-6 border border-pink-200">
                <h2 class="text-xl font-semibold text-gray-800 mb-3">Privacy Contact</h2>
                <p class="text-gray-700">
                    If you have questions about this Privacy Policy, please contact us at:
                </p>
                <ul class="mt-3 text-gray-700">
                    <li>📧 Email: privacy@airbnb.com</li>
                    <li>📞 Phone: +1 (555) 123-4567</li>
                    <li>📍 Address: 123 Main Street, San Francisco, CA 94105</li>
                </ul>
            </section>
        </div>

        <!-- Back to Signup Link -->
        <div class="text-center">
            <a href="/signup" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-700 hover:to-purple-700 text-white font-semibold rounded-lg transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Signup
            </a>
        </div>
    </div>
    
</body>
</html>